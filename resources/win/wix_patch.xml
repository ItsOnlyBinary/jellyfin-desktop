<CPackWiXPatch>
  <CPackWiXFragment Id="PRODUCT">
    <Property Id="DESKTOP_SHORTCUT" Value="1"/>
    <Component Id="DesktopShortcutUser" Guid="*">
      <Condition>DESKTOP_SHORTCUT=1 AND NOT ALLUSERS</Condition>
      <Shortcut Id="DesktopShortcutUser" Directory="DesktopFolder" Name="Jellyfin Desktop" Target="[INSTALLDIR]jellyfin-desktop.exe" WorkingDirectory="INSTALLDIR"/>
      <RegistryValue Root="HKCU" Key="Software\Jellyfin\Desktop" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
    </Component>
    <Component Id="DesktopShortcutMachine" Guid="*">
      <Condition>DESKTOP_SHORTCUT=1 AND ALLUSERS</Condition>
      <Shortcut Id="DesktopShortcutMachine" Directory="CommonDesktopFolder" Name="Jellyfin Desktop" Target="[INSTALLDIR]jellyfin-desktop.exe" WorkingDirectory="INSTALLDIR"/>
      <RegistryValue Root="HKLM" Key="Software\Jellyfin\Desktop" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
    </Component>
  </CPackWiXFragment>
  <CPackWiXFragment Id="TARGETDIR">
    <Directory Id="DesktopFolder"/>
    <Directory Id="CommonDesktopFolder"/>
  </CPackWiXFragment>
</CPackWiXPatch>
