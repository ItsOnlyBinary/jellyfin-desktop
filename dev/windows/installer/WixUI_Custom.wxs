<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <!--
      Extends WixUI_Advanced by inserting a desktop-shortcut checkbox dialog.
      Dialog sequence (modified):
        InstallScopeDlg -> DesktopShortcutDlg -> VerifyReadyDlg

      The <Publish> elements below override the Next/Back wiring of the
      neighboring dialogs. Order="3" runs after WixUI_Advanced's own
      Order=1/2 event handlers so ours wins.
    -->
    <UI Id="WixUI_Custom_DesktopShortcut">

      <Dialog Id="DesktopShortcutDlg" Width="370" Height="270"
              Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap"
                 X="0" Y="0" Width="370" Height="44"
                 TabSkip="no" Text="!(loc.InstallDirDlgBannerBitmap)" />
        <Control Id="BannerLine" Type="Line"
                 X="0" Y="44" Width="370" Height="0" />
        <Control Id="Title" Type="Text"
                 X="15" Y="6" Width="200" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text>{\WixUI_Font_Title}Installation Options</Text>
        </Control>
        <Control Id="Description" Type="Text"
                 X="25" Y="23" Width="280" Height="15"
                 Transparent="yes" NoPrefix="yes">
          <Text>Choose optional components.</Text>
        </Control>
        <Control Id="BottomLine" Type="Line"
                 X="0" Y="234" Width="370" Height="0" />

        <Control Id="DesktopShortcutCheck" Type="CheckBox"
                 X="20" Y="70" Width="330" Height="17"
                 Property="DESKTOPSHORTCUT" CheckBoxValue="1">
          <Text>Create a desktop shortcut</Text>
        </Control>

        <Control Id="Back" Type="PushButton"
                 X="180" Y="243" Width="56" Height="17"
                 Text="!(loc.WixUIBack)">
          <Publish Event="NewDialog" Value="InstallScopeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton"
                 X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="!(loc.WixUINext)">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>
        <Control Id="Cancel" Type="PushButton"
                 X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Rewire InstallScopeDlg Next -> our dialog (instead of VerifyReadyDlg) -->
      <Publish Dialog="InstallScopeDlg" Control="Next"
               Event="NewDialog" Value="DesktopShortcutDlg" Order="3" />

      <!-- Rewire VerifyReadyDlg Back -> our dialog (instead of InstallScopeDlg) -->
      <Publish Dialog="VerifyReadyDlg" Control="Back"
               Event="NewDialog" Value="DesktopShortcutDlg" Order="3" />

    </UI>
  </Fragment>
</Wix>
